{
  "name": "es-sink-product-master-v2",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "tasks.max": "1",
    "topics": "psql_ranking_poc.public.product_master",
    "connection.url": "${env:ELASTIC_URL}",
    "key.ignore": "true",
    "schema.ignore": "true",
    "compact.map.entries": "true",
    "behavior.on.null.values": "DELETE",
    "behavior.on.malformed.documents": "FAIL",
    "write.method": "UPSERT",
    "max.in.flight.requests": "1",
    "batch.size": "500",
    "max.retries": "8",
    "retry.backoff.ms": "500",
    "read.timeout.ms": "10000",
    "connection.timeout.ms": "3000",
    "topic.to.external.resource.mapping": "psql_ranking_poc.public.product_master:product_master_v2_write",
    "external.resource.usage": "ALIAS_INDEX",
    "transforms": "dropMeta",
    "transforms.dropMeta.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.dropMeta.exclude": "__op,__table,__lsn,__source_ts_ms,__deleted",
    "errors.tolerance": "none",
    "errors.deadletterqueue.topic.name": "dlq.product_master_v2.elasticsearch",
    "errors.deadletterqueue.context.headers.enable": "true",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "errors.deadletterqueue.topic.replication.factor": "1"
  }
}
