{
  "aliases": {
    "product_master_v2_read": {},
    "product_master_v2_write": {
      "is_write_index": true
    }
  },
  "settings": {
    "analysis": {
      "normalizer": {
        "v2_lowercase_normalizer": {
          "type": "custom",
          "filter": [
            "lowercase",
            "asciifolding"
          ]
        }
      },
      "filter": {
        "v2_model_ngram_filter": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 20
        },
        "v2_upc_ngram_filter": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 20
        }
      },
      "analyzer": {
        "v2_text_analyzer": {
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "asciifolding"
          ]
        },
        "v2_keyword_lowercase": {
          "tokenizer": "keyword",
          "filter": [
            "lowercase",
            "asciifolding"
          ]
        },
        "v2_model_partial_analyzer": {
          "tokenizer": "keyword",
          "filter": [
            "lowercase",
            "asciifolding",
            "v2_model_ngram_filter"
          ]
        },
        "v2_upc_partial_analyzer": {
          "tokenizer": "keyword",
          "filter": [
            "lowercase",
            "v2_upc_ngram_filter"
          ]
        }
      }
    }
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "uuid": {
        "type": "keyword"
      },
      "status": {
        "type": "keyword"
      },
      "type": {
        "type": "text",
        "analyzer": "v2_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "name": {
        "type": "text",
        "analyzer": "v2_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 512
          }
        }
      },
      "category": {
        "type": "text",
        "analyzer": "v2_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "sub_category": {
        "type": "text",
        "analyzer": "v2_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "brand": {
        "type": "text",
        "analyzer": "v2_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "manufacturer": {
        "type": "object",
        "enabled": true
      },
      "upc": {
        "type": "keyword",
        "normalizer": "v2_lowercase_normalizer",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "v2_keyword_lowercase"
          },
          "partial": {
            "type": "text",
            "analyzer": "v2_upc_partial_analyzer",
            "search_analyzer": "v2_keyword_lowercase"
          }
        }
      },
      "variant": {
        "type": "keyword"
      },
